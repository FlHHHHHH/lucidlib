local PAL = { Color3.fromRGB(255,157,94), Color3.fromRGB(255,107,157), Color3.fromRGB(176,107,255), Color3.fromRGB(255,107,157) }
local PN, FKP = #PAL, 10
local function palAt(u) u=u%1; local s=u*PN; local i=math.floor(s); local a=PAL[(i%PN)+1]; local b=PAL[((i+1)%PN)+1]; return a:Lerp(b,s-i) end
local function buildSeq(phase) local kp=table.create(FKP+1); for j=0,FKP do kp[j+1]=ColorSequenceKeypoint.new(j/FKP, palAt(j/FKP+phase)) end; return ColorSequence.new(kp) end
