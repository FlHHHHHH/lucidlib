    ----------------------------------------------------------------
    -- TAB / SUBTAB / SECTION
    ----------------------------------------------------------------
    local function selectTab(name)
        for n,t in pairs(win.tabs) do local sel=n==name
            t.subbar.Visible=sel and (t.multiSub==true);t.page.Visible=sel
            tw(t.hl,0.16,{BackgroundTransparency=sel and 0 or 1})
            tw(t.title,0.16,{TextColor3=sel and T.TextOn or T.Dim})
            if sel then t.page.Position=UDim2.fromOffset(0,t.pageY) end
        end
        win.activeTab=name
    end

    function win:Tab(o)
        o=o or {};local name=o.Title or "Tab";win.tabN+=1
        local btn=Instance.new("TextButton");btn.Size=UDim2.new(1,0,0,38);btn.BackgroundTransparency=1;btn.AutoButtonColor=false;btn.Text="";btn.LayoutOrder=win.tabN;btn.Parent=tabList
