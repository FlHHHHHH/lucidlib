local function tw(i,t,p,st) TweenS:Create(i,TweenInfo.new(t,st or Enum.EasingStyle.Quad,Enum.EasingDirection.Out),p):Play() end
local function grad2(i,a,b,rot) local g=Instance.new("UIGradient");g.Color=ColorSequence.new(a,b);g.Rotation=rot or 0;g.Parent=i;return g end
local function chevron(parent,color)
    local h=Instance.new("Frame");h.Size=UDim2.fromOffset(12,12);h.BackgroundTransparency=1;h.Parent=parent
    local a=Instance.new("Frame");a.AnchorPoint=Vector2.new(0.5,0.5);a.Position=UDim2.fromScale(0.32,0.42);a.Size=UDim2.fromOffset(7,1.6);a.BackgroundColor3=color;a.BorderSizePixel=0;a.Rotation=45;a.Parent=h;corner(a,1)
