            local colL=Instance.new("ScrollingFrame");colL.Size=UDim2.new(0.5,-16,1,-4);colL.Position=UDim2.fromOffset(14,2);colL.BackgroundTransparency=1;colL.BorderSizePixel=0;colL.ScrollBarThickness=3;colL.ScrollBarImageColor3=T.Line;colL.ScrollBarImageTransparency=0.3;colL.CanvasSize=UDim2.new();colL.AutomaticCanvasSize=Enum.AutomaticSize.Y;colL.Parent=pane;vlist(colL,16);pad(colL,4,2,4,12)
