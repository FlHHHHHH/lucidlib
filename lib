    return h
end

local FLOWREG = _G.__LucidFlow2
if not FLOWREG then
    FLOWREG = { grads = {} }; _G.__LucidFlow2 = FLOWREG
    RunS.Heartbeat:Connect(function()
        local seq = buildSeq((tick()*0.12) % 1); local g = FLOWREG.grads
        for i=#g,1,-1 do local gr=g[i]
            if gr.Parent then gr.Color=seq else table.remove(g,i) end
        end
    end)
end
local function flowGrad(inst, rot)
    local g=Instance.new("UIGradient");g.Color=buildSeq(0);g.Rotation=rot or 0;g.Parent=inst
    table.insert(FLOWREG.grads, g);return g
end

