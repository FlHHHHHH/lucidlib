        win.tabs[name]=tab

        btn.MouseEnter:Connect(function() if win.activeTab~=name then tw(hl,0.14,{BackgroundTransparency=0.6});tw(title,0.14,{TextColor3=T.Text}) end end)
        btn.MouseLeave:Connect(function() if win.activeTab~=name then tw(hl,0.14,{BackgroundTransparency=1});tw(title,0.14,{TextColor3=T.Dim}) end end)
        btn.MouseButton1Click:Connect(function() selectTab(name) end)

        local function selectSub(sname)
            for sn,s in pairs(tab.subs) do local sel=sn==sname;s.pane.Visible=sel
