local function corner(i,r) local c=Instance.new("UICorner");c.CornerRadius=UDim.new(0,r or 6);c.Parent=i;return c end
local function stroke(i,c,t,tr) local s=Instance.new("UIStroke");s.Color=c or Color3.new();s.Thickness=t or 1;s.Transparency=tr or 0;s.ApplyStrokeMode=Enum.ApplyStrokeMode.Border;s.Parent=i;return s end
local function pad(i,l,t,r,b) local p=Instance.new("UIPadding");p.PaddingLeft=UDim.new(0,l or 0);p.PaddingTop=UDim.new(0,t or 0);p.PaddingRight=UDim.new(0,r or 0);p.PaddingBottom=UDim.new(0,b or 0);p.Parent=i;return p end
local function vlist(i,g,a) local l=Instance.new("UIListLayout");l.Padding=UDim.new(0,g or 0);l.SortOrder=Enum.SortOrder.LayoutOrder;l.HorizontalAlignment=a or Enum.HorizontalAlignment.Left;l.Parent=i;return l end
local function hlist(i,g,a) local l=Instance.new("UIListLayout");l.FillDirection=Enum.FillDirection.Horizontal;l.Padding=UDim.new(0,g or 0);l.SortOrder=Enum.SortOrder.LayoutOrder;l.VerticalAlignment=a or Enum.VerticalAlignment.Center;l.Parent=i;return l end
local function txt(p,s,sz,c,f) local l=Instance.new("TextLabel");l.BackgroundTransparency=1;l.Font=f or FM;l.TextSize=sz;l.TextColor3=c or Color3.new(1,1,1);l.TextXAlignment=Enum.TextXAlignment.Left;l.Text=s;l.Parent=p;return l end
local function tw(i,t,p,st) TweenS:Create(i,TweenInfo.new(t,st or Enum.EasingStyle.Quad,Enum.EasingDirection.Out),p):Play() end
local function grad2(i,a,b,rot) local g=Instance.new("UIGradient");g.Color=ColorSequence.new(a,b);g.Rotation=rot or 0;g.Parent=i;return g end
local function chevron(parent,color)
    local h=Instance.new("Frame");h.Size=UDim2.fromOffset(12,12);h.BackgroundTransparency=1;h.Parent=parent
    local a=Instance.new("Frame");a.AnchorPoint=Vector2.new(0.5,0.5);a.Position=UDim2.fromScale(0.32,0.42);a.Size=UDim2.fromOffset(7,1.6);a.BackgroundColor3=color;a.BorderSizePixel=0;a.Rotation=45;a.Parent=h;corner(a,1)
    local b=Instance.new("Frame");b.AnchorPoint=Vector2.new(0.5,0.5);b.Position=UDim2.fromScale(0.68,0.42);b.Size=UDim2.fromOffset(7,1.6);b.BackgroundColor3=color;b.BorderSizePixel=0;b.Rotation=-45;b.Parent=h;corner(b,1)
    return h
end
-- ONE global Heartbeat drives every flow gradient (no leak across reloads)
local FLOWREG = _G.__LucidFlow2
if not FLOWREG then
    FLOWREG = { grads = {} }; _G.__LucidFlow2 = FLOWREG
    RunS.Heartbeat:Connect(function()
        local seq = buildSeq((tick()*0.12) % 1); local g = FLOWREG.grads
        for i=#g,1,-1 do local gr=g[i]
            if gr.Parent then gr.Color=seq else table.remove(g,i) end
        end
    end)
end
local function flowGrad(inst, rot)
    local g=Instance.new("UIGradient");g.Color=buildSeq(0);g.Rotation=rot or 0;g.Parent=inst
    table.insert(FLOWREG.grads, g);return g
end

